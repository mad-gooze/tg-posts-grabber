# LLM endpoint: OpenAI-compatible, or Anthropic Messages API if the URL contains "anthropic"
# LLM_API_KEY may be "file:<path>" to read the key from a gitignored file in the repo root
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Telegram bot (create via @BotFather, see README)
TG_BOT_TOKEN=123456:ABC-DEF...
TG_CHAT_ID=123456789

# Content-source tokens (only needed if you enable slack/discord sources; see docs/sources-setup.md).
# Each may be "file:<path>" to read from a gitignored file, like LLM_API_KEY.
# SLACK_TOKEN=xoxp-...        # Slack user token; per-workspace override via token_env in sources.yaml
# DISCORD_TOKEN=...           # user token from a throwaway account (self-bot — see the doc's warning)

# Pipeline tuning (optional, defaults shown)
RELEVANCE_THRESHOLD=7
MAX_LLM_ITEMS_PER_RUN=40
LOOKBACK_DAYS=3

# LLM token tuning (optional)
# CLASSIFY_MODEL=          # separate (cheaper) model for relevance scoring; defaults to LLM_MODEL
# CLASSIFY_BATCH_SIZE=8    # items scored per classify call (1 = old per-item behavior)

# SOCKS5 proxy for sources blocked on the local network (optional). Used by sources
# marked proxy: true in sources.yaml, and as an automatic retry when a direct fetch fails.
# socks5h:// resolves DNS on the proxy side (survives local DNS poisoning); may be "file:<path>"
# SOCKS5_PROXY=socks5h://user:pass@host:port
